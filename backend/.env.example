# backend/.env.example

# Application
APP_NAME=LocalRAGChatbot
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_chatbot
DATABASE_URL_SYNC=postgresql://rag_user:rag_password@localhost:5432/rag_chatbot

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMENSIONS=768

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# RAG
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVER_TOP_K=5